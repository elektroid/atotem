# Copy this file to .env and fill in your values.
# Actual .env is git-ignored — never commit secrets.

# ── Mistral ───────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# Reuse an existing agent instead of creating one on every cold start.
# Leave empty on first run; the agent ID will be printed in the logs.
MISTRAL_AGENT_ID=

# ── Server ────────────────────────────────────────────────
PORT=8080
HOST=              # empty = all interfaces (0.0.0.0); set to 127.0.0.1 for localhost only

# ── Storage ───────────────────────────────────────────────
DB_PATH=data/totem.db
IMAGES_DIR=data/images
